# ==============================================================================
# BeyondTech Predictive Maintenance - .gitignore
# ==============================================================================

# Generated Data Files (too large for git)
# These will be created by running: python synthetic_data_generator.py
Generated_output_data/*.xlsx
Generated_output_data/*.csv
!Generated_output_data/.gitkeep

# Trained Model Files (too large for git)  
# These will be created by running: python AI_prediction_model.py
Trained_Model/*.pkl
Trained_Model/*.joblib
!Trained_Model/.gitkeep

# Model Reports (generated files)
Model_Reports/*.txt
Model_Reports/*.csv
!Model_Reports/.gitkeep

# Benchmarking Reports (generated files)
Benchmarking_Reports/*.txt
Benchmarking_Reports/*.csv
Benchmarking_Reports/plots/*.png
Benchmarking_Reports/plots/*.jpg
!Benchmarking_Reports/.gitkeep
!Benchmarking_Reports/plots/.gitkeep

# Visualizations (generated plots)
Visualizations/*.png
Visualizations/*.jpg
Visualizations/*.pdf
!Visualizations/.gitkeep

# Python Cache
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyc
.Python

# Virtual Environments
.venv/
venv/
ENV/
env/
.virtualenv/
.env
.gradio

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
.env.example

# OS Generated
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# Jupyter Notebooks (if any)
.ipynb_checkpoints/
*.ipynb

# Distribution / Packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Logs
*.log
logs/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

Benchmarking_Reports/
Generated_output_data/
Model_Reports/
Public_Datasets/
Trained Model/
Trained_Model/
Visualizations/

# SOVD EACTROS Demo (separate project, not tracked)
sovd-eactros-demo/

# VED raw dataset (large download, not tracked)
10_Predictive Diagnostics/VED_Data/

# Augmented/processed datasets (generated files, regenerate with ved_data_processor.py)
10_Predictive Diagnostics/Augmented_Datasets/*.csv

# Claude Code memory (local AI assistant state)
.claude/

# ==============================================================================
# KEEP THESE FOLDERS BUT IGNORE THEIR CONTENTS
# ==============================================================================
# The .gitkeep files preserve folder structure while ignoring generated content